rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getRole() {
      return ('role' in request.auth.token) ? request.auth.token.role : 'user';
    }
    
    function isAdmin() {
      // Allow read/write for admin role, developer emails, and the specific test user ID
      return isAuthenticated() && (
        getRole() == 'admin' || 
        request.auth.token.email == 'lucaspferraz123@gmail.com' || 
        request.auth.token.email == 'noturcursos1@gmail.com' ||
        request.auth.uid == 'QAF43mllapOP6LtgiyTRkfUdei83' ||
        request.auth.uid == '675qOaE7wGUSFk45V0D39B1g9y93' // Often useful for other test admins
      );
    }

    function getUserTenant() {
      return ('tenantId' in request.auth.token) ? request.auth.token.tenantId : 'none';
    }

    function canReadContent(rsc) {
      return isAdmin() || (
        isAuthenticated() && 
        rsc != null && 
        rsc.data.get('tenant_id', '') == getUserTenant()
      );
    }

    function canWriteContent(reqRsc, rsc) {
      return isAdmin() || (
        isAuthenticated() &&
        (rsc == null || rsc.data.get('tenant_id', '') == getUserTenant()) &&
        (reqRsc == null || reqRsc.data.get('tenant_id', '') == getUserTenant())
      );
    }

    // By default, allow everything if the user is an admin, so we don't need to specify every single collection.
    // For non-admins, they must match specific collections.
    
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // ==========================================
    // EXPLICITLY REQUESTED COLLECTIONS
    // ==========================================

    match /tickets/{docId} {
      allow read: if canReadContent(resource);
      allow write: if canWriteContent(request.resource, resource);
      
      match /messages/{messageId} {
        allow read: if canReadContent(get(/databases/$(database)/documents/tickets/$(docId)));
        allow write: if canWriteContent(request.resource, resource);
      }
    }

    match /customers/{docId} {
      allow read: if canReadContent(resource);
      allow write: if canWriteContent(request.resource, resource);
      
      match /preferences/{prefId} {
        allow read, write: if canReadContent(get(/databases/$(database)/documents/customers/$(docId)));
      }
    }

    match /service_orders/{docId} {
      allow read: if canReadContent(resource);
      allow write: if canWriteContent(request.resource, resource);
    }

    match /knowledge_base/{docId} {
      allow read: if canReadContent(resource);
      allow write: if canWriteContent(request.resource, resource);
    }

    match /invoices/{docId} {
      allow read: if canReadContent(resource);
      allow write: if canWriteContent(request.resource, resource);
    }
    
    match /billing_invoices/{docId} {
      allow read: if canReadContent(resource);
      allow write: if canWriteContent(request.resource, resource);
    }

    match /ctos/{docId} {
      allow read: if canReadContent(resource);
      allow write: if canWriteContent(request.resource, resource);
    }

    match /csat_ratings/{docId} {
      allow read: if canReadContent(resource);
      allow write: if canWriteContent(request.resource, resource);
    }

    match /incidents/{docId} {
      allow read: if canReadContent(resource);
      allow write: if canWriteContent(request.resource, resource);
    }

    match /contracts/{docId} {
      allow read: if canReadContent(resource);
      allow write: if canWriteContent(request.resource, resource);
    }

    match /inventory/{docId} {
      allow read: if canReadContent(resource);
      allow write: if canWriteContent(request.resource, resource);
    }

    match /network_ctos/{docId} {
      allow read: if canReadContent(resource);
      allow write: if canWriteContent(request.resource, resource);
    }

    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    match /tenants/{tenantId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      
      match /settings/{settingId} {
        allow read, write: if isAdmin() || (isAuthenticated() && getUserTenant() == tenantId);
      }
    }
    
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /logs/{logId} {
      allow read: if canReadContent(resource);
      allow write: if canWriteContent(request.resource, resource);
    }
    
    match /prompts/{tenantId} {
      allow read: if isAdmin() || (isAuthenticated() && getUserTenant() == tenantId);
      allow write: if isAdmin() || (isAuthenticated() && getUserTenant() == tenantId);
      match /versions/{versionId} {
        allow read, write: if isAdmin() || (isAuthenticated() && getUserTenant() == tenantId);
      }
    }
    
    match /plans/{tenantId} {
      allow read: if isAdmin() || (isAuthenticated() && getUserTenant() == tenantId);
      allow write: if isAdmin();
    }
    
    match /team_members/{memberId} {
      allow read: if canReadContent(resource) || (isAuthenticated() && resource.data.email == request.auth.token.email);
      allow write: if canWriteContent(request.resource, resource) || (isAuthenticated() && request.resource.data.email == request.auth.token.email);
    }
    
    match /payments/{paymentId} {
      allow read: if canReadContent(resource);
      allow write: if canWriteContent(request.resource, resource);
    }
    
    match /ai_usage/{logId} {
      allow read: if canReadContent(resource);
      allow write: if canWriteContent(request.resource, resource);
    }
    
    match /audit_logs/{logId} {
      allow read: if canReadContent(resource);
      allow write: if canWriteContent(request.resource, resource);
    }
    
    match /notifications/{notificationId} {
      allow read: if canReadContent(resource);
      allow write: if canWriteContent(request.resource, resource);
    }
    
    // Add missing collections
    match /technicians/{tenantId} {
      allow read, write: if isAdmin() || (isAuthenticated() && getUserTenant() == tenantId);
      match /list/{techId} {
        allow read, write: if isAdmin() || (isAuthenticated() && getUserTenant() == tenantId);
      }
    }
    match /cobrai_logs/{docId} {
      allow read: if canReadContent(resource);
      allow write: if canWriteContent(request.resource, resource);
    }
    match /dead_letter_queue/{docId} {
      allow read: if canReadContent(resource);
      allow write: if canWriteContent(request.resource, resource);
    }
    match /ai_token_logs/{docId} {
      allow read: if canReadContent(resource);
      allow write: if canWriteContent(request.resource, resource);
    }
    match /ai_provider_configs/{docId} {
      allow read: if canReadContent(resource);
      allow write: if canWriteContent(request.resource, resource);
    }
    match /portability_requests/{docId} {
      allow read: if canReadContent(resource);
      allow write: if canWriteContent(request.resource, resource);
    }
    match /cto_incidents/{docId} {
      allow read: if canReadContent(resource);
      allow write: if canWriteContent(request.resource, resource);
    }
    match /agent_metrics/{docId} {
      allow read: if canReadContent(resource);
      allow write: if canWriteContent(request.resource, resource);
    }
    match /metrics_shards/{docId} {
      allow read: if canReadContent(resource);
      allow write: if canWriteContent(request.resource, resource);
    }
    match /usage_stats/{docId} {
      allow read: if canReadContent(resource);
      allow write: if canWriteContent(request.resource, resource);
    }
    match /security_logs/{docId} {
      allow read: if canReadContent(resource);
      allow write: if canWriteContent(request.resource, resource);
    }
  }
}
