{
  "name": "astrum-monorepo",
  "private": true,
  "packageManager": "npm@10.9.8",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "version": "1.0.0",
  "type": "module",
  "_migration_notes": "Firebase removido Sprint 0 Dia 8. Migrado para Supabase.",
  "scripts": {
    "dev:turbo": "turbo run dev",
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:turbo": "turbo run build",
    "test:unit": "vitest run",
    "test:e2e": "cd apps/web && npx playwright test",
    "test:e2e:headed": "cd apps/web && npx playwright test --headed",
    "test:all": "npm run test:unit && npm run test:e2e",
    "test:turbo": "turbo run test",
    "typecheck": "turbo run typecheck",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f api",
    "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up redis qdrant",
    "docker:health": "curl -f http://localhost:3001/api/v2/health",
    "start": "node dist/server.cjs"
  },
