# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# EVOLUTION_WEBHOOK_SECRET: Chave para validação da assinatura HMAC (Autenticação do Webhook).
# Este valor é configurado no painel da Evolution API ou na criação da instância, geralmente referenciado como 'webhookSecret'.
EVOLUTION_WEBHOOK_SECRET="seu_webhook_secret_aqui"

# SUPABASE CONFIGURATION (Para migração futura)
# Estas chaves são necessárias se você decidir mudar do Firebase para o Supabase.
VITE_SUPABASE_URL="sua_url_do_supabase_aqui"
VITE_SUPABASE_ANON_KEY="sua_anon_key_do_supabase_aqui"

# REDIS_URL: Connection URL for Redis instances (Idempotency, Debounce, BullMQ)
REDIS_URL="redis://localhost:6379"

# WORKER_CONCURRENCY: Default concurrency for the BullMQ message worker
WORKER_CONCURRENCY="5"

# Máximo de mensagens de cobrança por hora. Aumentar progressivamente conforme histórico do número WhatsApp: 30 para números novos, até 100 para números com >6 meses.
COBRAI_HOURLY_LIMIT="30"

# CPF_ENCRYPTION_KEY: Chave de 32 bytes em hex para criptografia AES-256-GCM dos CPFs.
# Gere uma chave com o comando: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VITE_CPF_ENCRYPTION_KEY="sua_chave_hex_de_32_bytes_aqui"

# INCIDENT_THRESHOLD: Limite de chamados para um agrupamento de incidente
INCIDENT_THRESHOLD="5"

# NOC_WEBHOOK_SECRET: Chave para validação da assinatura HMAC do Webhook do NOC
NOC_WEBHOOK_SECRET="seu_noc_secret_aqui"

# NOC_ALERT_SEVERITY_THRESHOLD: Nível mínimo de severidade do Zabbix (1-5) para acionar alertas
NOC_ALERT_SEVERITY_THRESHOLD="3"

# OPENAI_API_KEY: Chave para a OpenAI (Whisper, Classificador base, etc)
OPENAI_API_KEY="sua_chave_openai_aqui"

# ANTHROPIC_API_KEY: Chave para o Claude da Anthropic
ANTHROPIC_API_KEY="sua_chave_anthropic_aqui"

# FIREBASE BACKUP:
BACKUP_BUCKET_NAME="astrum-backups-prod"
GCLOUD_PROJECT="seu-projeto-firebase"

# Provedor de Embeddings (traduz texto em números para busca semântica)
EMBEDDING_PROVIDER=openai         # openai | cohere | mistral | local
EMBEDDING_API_KEY=                # chave do provedor escolhido
EMBEDDING_MODEL=text-embedding-3-small   # modelo a usar
EMBEDDING_BASE_URL=               # necessário apenas para provedores alternativos
EMBEDDING_DIMENSIONS=1536         # dimensões do modelo (1536 para OpenAI small)

# Banco de dados vetorial (guarda e busca os números dos embeddings)
VECTOR_STORE_PROVIDER=qdrant      # qdrant | pinecone | weaviate

DB_PROVIDER=firebase   # firebase | supabase — trocar quando migração estiver pronta
VECTOR_STORE_URL=                 # URL da instância (ex: https://sua-instancia.qdrant.io)
VECTOR_STORE_API_KEY=             # chave de acesso
VECTOR_STORE_COLLECTION=astrum_knowledge  # nome da coleção/índice
VECTOR_MIN_SCORE=0.7   # score mínimo de relevância (0 a 1). Aumentar = mais restrito.
