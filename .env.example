# ═══════════════════════════════════════════
# ASTRUM AI ENGINE — Variáveis de Ambiente
# Copie para .env e preencha com valores reais
# NUNCA commite o arquivo .env
# ═══════════════════════════════════════════

# Servidor
NODE_ENV=development
PORT=3000
FASTIFY_PORT=3001
LOG_LEVEL=info

# Supabase (obrigatório)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Redis
REDIS_URL=redis://localhost:6379

# OpenAI (obrigatório)
OPENAI_API_KEY=sk-...

# JWT (obrigatório — mínimo 32 chars)
JWT_SECRET=mude-isso-para-string-aleatoria-de-64-chars

# CORS
ALLOWED_ORIGINS=http://localhost:5173,https://app.astrum.com.br

# WhatsApp / Evolution API (Sprint 1)
EVOLUTION_API_URL=https://sua-evolution.com
EVOLUTION_API_KEY=

# Helicone — FinOps IA (Sprint 2)
HELICONE_API_KEY=

# Sentry — Observabilidade (Sprint 3)
SENTRY_DSN=

# LangSmith — Tracing IA (Sprint 3)
LANGCHAIN_API_KEY=ls__sua_chave_aqui
LANGCHAIN_TRACING=true
LANGCHAIN_PROJECT=astrum-production

# HMAC — Webhooks (Sprint 1)
EVOLUTION_WEBHOOK_SECRET=mude-para-secret-configurado-na-evolution-api
FACEBOOK_APP_SECRET=mude-para-app-secret-do-facebook-developers
PAYMENT_WEBHOOK_SECRET=mude-para-secret-do-gateway-de-pagamento
WEBHOOK_HMAC_SECRET=fallback-para-webhooks-genericos-min-32-chars

# Cloudflare R2 — Storage (Sprint 1)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=astrum-documents

# Qdrant Vector DB
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=   # obrigatório apenas em Qdrant Cloud

# Zep — Memória de Longo Prazo (opcional, fail-open se não configurado)
ZEP_API_URL=http://localhost:8000
ZEP_API_KEY=your-zep-api-key
# Zep Cloud: https://cloud.getzep.com
# Self-hosted: docker run -p 8000:8000 ghcr.io/getzep/zep

# Cloudflare R2 (zero egress fees)
CLOUDFLARE_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=astrum-storage
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Svix — Outbound Webhooks
SVIX_API_KEY=your-svix-api-key
# Criar em: https://dashboard.svix.com

# Cloudflare Workers
CLOUDFLARE_ACCOUNT_ID=your-account-id
# Deploy: npx wrangler deploy