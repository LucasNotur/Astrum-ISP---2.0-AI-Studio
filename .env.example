# ASTRUM AI ENGINE â€” VariÃ¡veis de Ambiente
# Copie para .env e preencha com valores reais
# NUNCA commite o arquivo .env
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•

# Servidor
NODE_ENV=development
PORT=3000
FASTIFY_PORT=3001
LOG_LEVEL=info

# Supabase (obrigatÃ³rio)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=seu-jwt-secret-do-dashboard   # Settings -> API -> JWT Secret (FZ-3: verificação de tokens no backend)

# â”€â”€â”€ Redis (obrigatÃ³rio â€” mÃ­nimo 32 chars) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
REDIS_PASSWORD=GERAR_COM_OPENSSL_NAO_USAR_ESTE_VALOR
# O formato da URL inclui a senha inline:
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379
# Em dev local sem Docker: redis://:${REDIS_PASSWORD}@localhost:6379

# â”€â”€â”€ Qdrant (obrigatÃ³rio em produÃ§Ã£o) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Gerar com: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
QDRANT_API_KEY=GERAR_COM_OPENSSL_NAO_USAR_ESTE_VALOR
QDRANT_URL=http://qdrant:6333
# Em dev local sem Docker: http://localhost:6333

# â”€â”€â”€ Zep (memÃ³ria de longo prazo) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# DSN com usuÃ¡rio zep_user de least-privilege (ver infra/sql/create-zep-user.sql)
ZEP_POSTGRES_DSN=postgres://zep_user:SENHA_ZEP@db.xxx.supabase.co:5432/postgres?search_path=zep
ZEP_API_URL=http://zep:8000
ZEP_API_KEY=your-zep-api-key

# OpenAI (obrigatÃ³rio)
OPENAI_API_KEY=sk-...

# JWT (obrigatÃ³rio â€” mÃ­nimo 64 chars)
# Gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GERAR_COM_OPENSSL_MINIMO_64_CHARS_NAO_USAR_ESTE_VALOR

# CORS
ALLOWED_ORIGINS=http://localhost:5173,https://app.astrum.com.br

# WhatsApp / Evolution API
EVOLUTION_API_URL=https://sua-evolution.com
EVOLUTION_API_KEY=
EVOLUTION_WEBHOOK_SECRET=GERAR_COM_OPENSSL_NAO_USAR_ESTE_VALOR

# Webhooks HMAC
FACEBOOK_APP_SECRET=
PAYMENT_WEBHOOK_SECRET=
WEBHOOK_HMAC_SECRET=GERAR_COM_OPENSSL_MINIMO_32_CHARS

# Helicone â€” FinOps IA
HELICONE_API_KEY=

# Sentry â€” Observabilidade
SENTRY_DSN=

# LangSmith â€” Tracing IA
# ATENÃ‡ÃƒO: em produÃ§Ã£o, LANGCHAIN_TRACING=false para nÃ£o vazar dados de clientes
LANGCHAIN_API_KEY=ls__sua_chave_aqui
LANGCHAIN_TRACING=false
LANGCHAIN_PROJECT=astrum-production

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=astrum-documents
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Svix â€” Outbound Webhooks
SVIX_API_KEY=your-svix-api-key

# Cloudflare Workers
CLOUDFLARE_ACCOUNT_ID=your-account-id
# â”€â”€â”€ Engine Flags (S68 â€” ContenÃ§Ã£o Strangler Fig) â”€â”€â”€
# Controla qual implementaÃ§Ã£o sobe por domÃ­nio durante a migraÃ§Ã£o. Ver CLAUDE.md R6.
# Apenas UMA engine por domÃ­nio pode estar ativa (evita cobranÃ§a/atendimento duplo).
COBRAI_ENGINE=legacy        # legacy | v2  (cutover na S76)
ATENDIMENTO_ENGINE=legacy   # legacy | v2  (cutover na S74)
MULTI_AGENT_ENABLED=false   # true | false  (IA-10; só ativa quando ATENDIMENTO_ENGINE=v2)

# --- IA-NEXTGEN Feature Flags (Parte 2) ---
INTELLIGENCE_HUB_ENABLED=false   # true | false  (IA-11; ativa Central de Inteligência no nav)
